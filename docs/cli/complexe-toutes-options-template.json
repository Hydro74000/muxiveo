{
  "version": 1,
  "kind": "exact-job",
  "tracks": [
    {
      "selector": {"source": 0, "type": "video", "position": 0},
      "enabled": true
    },
    {
      "selector": {"source": 0, "type": "audio", "position": 0},
      "enabled": true,
      "language": "fr-FR",
      "title": "French EAC3 5.1"
    },
    {
      "selector": {"source": 0, "type": "subtitle", "position": 0},
      "enabled": true,
      "language": "fr-FR"
    }
  ],
  "chapters": {
    "source_index": 0,
    "include_source": true,
    "import": "chapters-common.ffmetadata",
    "add": [
      {
        "timestamp": "00:00:00.000",
        "chaptername": "Opening"
      },
      {
        "timestamp": "00:42:00.000",
        "chaptername": "Credits"
      }
    ]
  },
  "tmdb": {
    "enabled": true,
    "kind": "tv",
    "language": "fr-FR",
    "season": "1"
  },
  "extra_attachments": [
    "cover.jpg",
    "font.ttf"
  ],
  "tag_overrides": {
    "ENCODER_SETTINGS": "muxiveo --cli template series-v1"
  },
  "work_dir": "/tmp/Muxiveo_work"
}
