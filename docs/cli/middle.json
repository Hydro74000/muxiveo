{
  "version": 1,
  "sources": [
    {
      "path": "Episode.S01E01.source.mkv",
      "attachments": "none",
      "copy_tags": false
    }
  ],
  "output": "Episode.S01E01.remux.mkv",
  "rules": {
    "normalize_languages": true,
    "tracks": {
      "video": {
        "include": true
      },
      "audio": {
        "include": true,
        "languages": ["fr-FR", "en-US"],
        "rename_pattern": "{LangName} {codec} {channels} {atmos}"
      },
      "subtitle": {
        "include": true,
        "languages": ["fr-FR", "en-US"],
        "rename_pattern": "{LangName} {tag_forced} {tag_malentendant}"
      }
    }
  },
  "chapters": {
    "source_index": 0
  }
}

