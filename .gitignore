__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
*.whl
MANIFEST
pip-wheel-metadata/
share/python-wheels/
.Python

# ---------------------------------------------------------------------------
# Environnements virtuels
# ---------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Tests & couverture
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover
*.log

# ---------------------------------------------------------------------------
# Mypy / type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# PyInstaller & packaging
# ---------------------------------------------------------------------------
build/
dist/
*.spec
Muxiveo.spec

# ---------------------------------------------------------------------------
# AppImage
# ---------------------------------------------------------------------------
Muxiveo.AppDir/
*.AppImage
appimagetool-*.AppImage
*.zsync

# ---------------------------------------------------------------------------
# Windows packaging (Wine cross-build)
# ---------------------------------------------------------------------------
Muxiveo-win/
Muxiveo-Setup.exe
Muxiveo.nsi
.wine_build/
python-*.exe

# ---------------------------------------------------------------------------
# Config locale (ne pas versionner les surcharges utilisateur)
# ---------------------------------------------------------------------------
config.ini
config.ini
.claude/
Muxiveo-Setup*.exe
ignore.md
.codex
mypy.ini
project_map.html
tools/*

# Ignore all .md files except READMEs
*.md
!README*.md
!Readme*.md